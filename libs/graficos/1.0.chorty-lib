{
  "id": "graficos",
  "alias": "gf",
  "versao": "1.0",
  "autor": "comunidade-chorty",
  "descricao": "Graficos SVG nativos — barras, linhas, pizza, area, horizontais e empilhados. Renderizacao pura sem dependencias externas.",

  "estilos": ".gf-grafico{position:relative;width:100%;overflow:hidden;}.gf-grafico svg{display:block;width:100%;}.gf-legenda{display:flex;flex-wrap:wrap;gap:12px;justify-content:center;margin-top:12px;}.gf-legenda-item{display:flex;align-items:center;gap:6px;font-size:12px;color:#64748b;}.gf-legenda-cor{width:12px;height:12px;border-radius:3px;}.gf-tooltip{position:absolute;background:#0f172a;color:#fff;padding:6px 10px;border-radius:6px;font-size:11px;pointer-events:none;opacity:0;transition:opacity 0.2s;white-space:nowrap;}.gf-titulo{font-size:14px;font-weight:600;color:#1e293b;margin-bottom:16px;text-align:center;}.gf-barra{transition:height 0.5s ease,width 0.5s ease;}.gf-barra:hover{opacity:0.85;}.gf-linha-ponto{transition:all 0.3s ease;}.gf-linha-ponto:hover{stroke-width:4;}.gf-fatia{transition:transform 0.3s ease;cursor:pointer;}.gf-fatia:hover{transform:scale(1.03);}.gf-eixo text{font-size:10px;fill:#94a3b8;font-family:system-ui,sans-serif;}.gf-eixo-linha{stroke:#e2e8f0;stroke-width:1;}.gf-grade-linha{stroke:#f1f5f9;stroke-width:1;}",

  "scripts": "window.gf={_cores:['#2563eb','#16a34a','#7c3aed','#ea580c','#0891b2','#db2777','#ca8a04','#64748b','#0d9488','#4338ca'],_resolverCor:function(c){var m={azul:'#2563eb',verde:'#16a34a',vermelho:'#dc2626',amarelo:'#ca8a04',laranja:'#ea580c',roxo:'#7c3aed',rosa:'#db2777',ciano:'#0891b2',turquesa:'#0d9488',indigo:'#4338ca',cinza:'#64748b',preto:'#0f172a',branco:'#ffffff'};return m[c]||c;},_maximo:function(s){var m=0;s.forEach(function(s){s.valores.forEach(function(v){if(v>m)m=v;});});return m*1.1||1;},_barras:function(r,s,h,cor){var svg='';var w=800,pad={top:20,right:20,bottom:40,left:50},cw=w-pad.left-pad.right,ch=h-pad.top-pad.bottom;var max=this._maximo(s);var n=s.length,m=s[0]?s[0].valores.length:0;var bw=(cw/m-4)/n;for(var i=0;i<m;i++){for(var si=0;si<n;si++){var x=pad.left+i*(cw/m)+si*bw;var bh=(s[si].valores[i]/max)*ch;var y=pad.top+ch-bh;svg+='<rect class=\"gf-barra\" x=\"'+x+'\" y=\"'+y+'\" width=\"'+(bw-1)+'\" height=\"'+bh+'\" fill=\"'+this._cores[si%this._cores.length]+'\" rx=\"2\"/>';}}svg+=this._eixoY(pad,ch,max);if(r&&r.length>0){for(var i=0;i<m;i++){var x=pad.left+i*(cw/m)+cw/m/2;var y=pad.top+ch+16;svg+='<text x=\"'+x+'\" y=\"'+y+'\" text-anchor=\"middle\" class=\"gf-eixo\">'+r[i]+'</text>';}}return svg;},_eixoY:function(p,ch,max){var s='',passos=4;for(var i=0;i<=passos;i++){var v=Math.round(max*i/passos);var y=p.top+ch-(ch*i/passos);s+='<text x=\"'+(p.left-6)+'\" y=\"'+(y+4)+'\" text-anchor=\"end\" class=\"gf-eixo\">'+v+'</text>';s+='<line x1=\"'+p.left+'\" y1=\"'+y+'\" x2=\"'+(800-p.right)+'\" y2=\"'+y+'\" class=\"gf-grade-linha\"/>';}return s;},_linhas:function(r,s,h,cor){var svg='';var w=800,pad={top:20,right:20,bottom:40,left:50},cw=w-pad.left-pad.right,ch=h-pad.top-pad.bottom;var max=this._maximo(s);var m=s[0]?s[0].valores.length:0;svg+=this._eixoY(pad,ch,max);for(var si=0;si<s.length;si++){var d='',corS=this._cores[si%this._cores.length];for(var i=0;i<m;i++){var x=pad.left+i*(cw/(m-1||1));var y=pad.top+ch-(s[si].valores[i]/max)*ch;d+=(i===0?'M':'L')+x+' '+y+' ';}svg+='<path d=\"'+d+'\" fill=\"none\" stroke=\"'+corS+'\" stroke-width=\"2\" class=\"gf-linha-ponto\"/>';for(var i=0;i<m;i++){var x=pad.left+i*(cw/(m-1||1));var y=pad.top+ch-(s[si].valores[i]/max)*ch;svg+='<circle cx=\"'+x+'\" cy=\"'+y+'\" r=\"3\" fill=\"'+corS+'\" class=\"gf-linha-ponto\"/>';}}if(r&&r.length>0){for(var i=0;i<m;i++){var x=pad.left+i*(cw/(m-1||1));var y=pad.top+ch+16;svg+='<text x=\"'+x+'\" y=\"'+y+'\" text-anchor=\"middle\" class=\"gf-eixo\">'+r[i]+'</text>';}}return svg;},_pizza:function(r,v,h,cor){var svg='';var cx=400,cy=h/2,r=Math.min(cx,cy)-20;var total=v.reduce(function(a,b){return a+b;},0);var angulo=0;for(var i=0;i<v.length;i++){var fatia=v[i]/total*Math.PI*2;var x1=cx+r*Math.cos(angulo);var y1=cy+r*Math.sin(angulo);var x2=cx+r*Math.cos(angulo+fatia);var y2=cy+r*Math.sin(angulo+fatia);var grande=fatia>Math.PI?1:0;svg+='<path d=\"M'+cx+' '+cy+' L'+x1+' '+y1+' A'+r+' '+r+' 0 '+grande+' 1 '+x2+' '+y2+' Z\" fill=\"'+this._cores[i%this._cores.length]+'\" class=\"gf-fatia\"/>';if(r&&r[i]){var mx=cx+(r*0.7)*Math.cos(angulo+fatia/2);var my=cy+(r*0.7)*Math.sin(angulo+fatia/2);svg+='<text x=\"'+mx+'\" y=\"'+my+'\" text-anchor=\"middle\" fill=\"#fff\" font-size=\"11\" font-weight=\"600\">'+Math.round(v[i]/total*100)+'%</text>';}angulo+=fatia;}return svg;},_area:function(r,s,h,cor){var svg='';var w=800,pad={top:20,right:20,bottom:40,left:50},cw=w-pad.left-pad.right,ch=h-pad.top-pad.bottom;var max=this._maximo(s);var m=s[0]?s[0].valores.length:0;svg+=this._eixoY(pad,ch,max);for(var si=0;si<s.length;si++){var d='',corS=this._cores[si%this._cores.length];d+='M'+pad.left+' '+(pad.top+ch)+' ';for(var i=0;i<m;i++){var x=pad.left+i*(cw/(m-1||1));var y=pad.top+ch-(s[si].valores[i]/max)*ch;d+='L'+x+' '+y+' ';}d+='L'+(pad.left+(m-1)*(cw/(m-1||1)))+' '+(pad.top+ch)+' Z';svg+='<path d=\"'+d+'\" fill=\"'+corS+'\" opacity=\"0.3\"/>';svg+='<path d=\"'+d.replace('M'+pad.left+' '+(pad.top+ch)+' L','M').replace('L'+(pad.left+(m-1)*(cw/(m-1||1)))+' '+(pad.top+ch)+' Z','')+'\" fill=\"none\" stroke=\"'+corS+'\" stroke-width=\"2\"/>';}if(r&&r.length>0){for(var i=0;i<m;i++){var x=pad.left+i*(cw/(m-1||1));svg+='<text x=\"'+x+'\" y=\"'+(pad.top+ch+16)+'\" text-anchor=\"middle\" class=\"gf-eixo\">'+r[i]+'</text>';}}return svg;},_horizontal:function(r,s,h,cor){var svg='';var w=800,pad={top:20,right:80,bottom:20,left:80},cw=w-pad.left-pad.right,ch=h-pad.top-pad.bottom;var max=this._maximo(s);var n=s.length,m=s[0]?s[0].valores.length:0;var bh=(ch/m-4)/n;for(var i=0;i<m;i++){for(var si=0;si<n;si++){var y=pad.top+i*(ch/m)+si*bh;var bw=(s[si].valores[i]/max)*cw;svg+='<rect class=\"gf-barra\" x=\"'+pad.left+'\" y=\"'+y+'\" width=\"'+bw+'\" height=\"'+(bh-1)+'\" fill=\"'+this._cores[si%this._cores.length]+'\" rx=\"2\"/>';var vx=pad.left+bw+4;var vy=y+bh/2+4;svg+='<text x=\"'+vx+'\" y=\"'+vy+'\" fill=\"#94a3b8\" font-size=\"10\">'+s[si].valores[i]+'</text>';}}if(r&&r.length>0){for(var i=0;i<m;i++){var y=pad.top+i*(ch/m)+ch/m/2+4;svg+='<text x=\"'+(pad.left-6)+'\" y=\"'+y+'\" text-anchor=\"end\" class=\"gf-eixo\">'+r[i]+'</text>';}}return svg;},_renderizar:function(id,dados,opcoes){var c=document.getElementById(id);if(!c)return;var t=opcoes.tipo||'barras';var a=parseInt(opcoes.altura)||300;var tit=opcoes.titulo||'';var rotulos=dados.rotulos||[];var series=dados.series||[];var svg='';if(t==='barras')svg=this._barras(rotulos,series,a);else if(t==='linhas')svg=this._linhas(rotulos,series,a);else if(t==='pizza')svg=this._pizza(rotulos,series[0]?series[0].valores:[],a);else if(t==='area')svg=this._area(rotulos,series,a);else if(t==='horizontal')svg=this._horizontal(rotulos,series,a);var html='';if(tit)html+='<div class=\"gf-titulo\">'+tit+'</div>';html+='<svg viewBox=\"0 0 800 '+a+'\" style=\"width:100%;height:'+a+'px;\">'+svg+'</svg>';if(series.length>1){html+='<div class=\"gf-legenda\">';series.forEach(function(s,i){html+='<div class=\"gf-legenda-item\"><div class=\"gf-legenda-cor\" style=\"background:'+this._cores[i%this._cores.length]+'\"></div>'+s.nome+'</div>';},this);html+='</div>';}c.innerHTML=html;}};",

  "componentes": {
    "grafico": {
      "template": "<div id=\"{{id}}\" class=\"gf-grafico\" style=\"{{estilo}}\"></div><script>gf._renderizar('{{id}}',{rotulos:[{{rotulos}}],series:[{{series}}]},{tipo:'{{tipo}}',altura:{{altura}},cor:'{{cor}}',titulo:'{{titulo}}',sombra:'{{sombra}}',espaco:{{espaco}},margem:{{margem}}});</script>",
      "atributos": ["id", "tipo", "altura", "cor", "titulo", "rotulos", "series", "estilo", "sombra", "espaco", "margem"]
    }
  },

  "funcoes": {}
}