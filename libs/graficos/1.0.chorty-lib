{
  "id": "graficos",
  "alias": "gt",
  "versao": "1.0",
  "autor": "comunidade-chorty",
  "descricao": "Pacote unificado de gráficos SVG nativos — barras, linhas, pizza, área e radar num único componente. Lê directamente arrays de dados TOON.",

  "estilos": ".gf-grafico{width:100%;overflow:hidden;position:relative;}.gf-grafico svg{display:block;width:100%;}.gf-titulo{font-size:14px;font-weight:600;color:#1e293b;margin-bottom:16px;text-align:center;}.gf-barra{transition:opacity 0.3s ease;}.gf-barra:hover{opacity:0.85;cursor:pointer;}.gf-linha{transition:all 0.3s ease;}.gf-ponto{transition:all 0.3s ease;}.gf-ponto:hover{r:5;}.gf-area{transition:opacity 0.3s ease;}.gf-fatia{transition:transform 0.3s ease;cursor:pointer;}.gf-fatia:hover{transform:scale(1.03);opacity:0.9;}.gf-eixo text{font-size:10px;fill:#94a3b8;font-family:system-ui,sans-serif;}.gf-grade-linha{stroke:#f1f5f9;stroke-width:1;}.gf-legenda{display:flex;flex-wrap:wrap;gap:12px;justify-content:center;margin-top:12px;}.gf-legenda-item{display:flex;align-items:center;gap:6px;font-size:12px;color:#64748b;}.gf-legenda-cor{width:12px;height:12px;border-radius:3px;}.gf-radar-area{transition:opacity 0.3s ease;}.gf-radar-eixo{stroke:#e2e8f0;stroke-width:1;}.gf-radar-anel{fill:none;stroke:#f1f5f9;stroke-width:1;}.gf-radar-rotulo{font-size:11px;fill:#64748b;font-family:system-ui,sans-serif;}",

  "scripts": "window.gt=window.gt||{_coresNomes:{azul:'#2563eb',verde:'#16a34a',vermelho:'#dc2626',amarelo:'#ca8a04',laranja:'#ea580c',roxo:'#7c3aed',rosa:'#db2777',ciano:'#0891b2',turquesa:'#0d9488',indigo:'#4338ca',cinza:'#64748b',preto:'#0f172a',branco:'#ffffff'},_cores:['#2563eb','#16a34a','#7c3aed','#ea580c','#0891b2','#db2777','#ca8a04','#64748b','#0d9488','#4338ca'],_resolverCor:function(nome){return this._coresNomes[nome]||nome||'#2563eb';},_maximo:function(valoresPorCampo){var m=0;valoresPorCampo.forEach(function(arr){arr.forEach(function(v){if(v>m)m=v;});});return Math.max(m*1.1,1);},_extrair:function(itens,opcoes){var camposValor=opcoes.valor.split(',').map(function(s){return s.trim();});var campoRotulo=opcoes.rotulo;var rotulos=campoRotulo?itens.map(function(d){return d[campoRotulo];}):[];var valoresPorCampo=camposValor.map(function(cv){return itens.map(function(d){return Number(d[cv])||0;});});return{camposValor:camposValor,rotulos:rotulos,valoresPorCampo:valoresPorCampo};},_render:function(id,itens,opcoes){var c=document.getElementById(id);if(!c||!itens||!itens.length)return;var tipo=opcoes.tipo||'barras';if(tipo==='barras')return this._barras(c,itens,opcoes);if(tipo==='linhas')return this._linhas(c,itens,opcoes);if(tipo==='pizza')return this._pizza(c,itens,opcoes);if(tipo==='area')return this._area(c,itens,opcoes);if(tipo==='radar')return this._radar(c,itens,opcoes);},_barras:function(c,itens,opcoes){var d=this._extrair(itens,opcoes),rotulos=d.rotulos,vpc=d.valoresPorCampo,altura=parseInt(opcoes.altura)||300,conteudo=opcoes.conteudo||'',cor=opcoes.cor||'',w=800,pl=50,pr=20,pt=20,pb=40,cw=w-pl-pr,ch=altura-pt-pb,max=this._maximo(vpc),n=d.camposValor.length,m=rotulos.length||1,bw=(cw/m-4)/n,svg='';for(var i=0;i<m;i++){for(var si=0;si<n;si++){var x=pl+i*(cw/m)+si*bw,bh=(vpc[si][i]/max)*ch,y=pt+ch-bh,corBarra=cor?this._resolverCor(cor):this._cores[si%10];svg+='<rect class=\"gf-barra\" x=\"'+x+'\" y=\"'+y+'\" width=\"'+(bw-1)+'\" height=\"'+bh+'\" fill=\"'+corBarra+'\" rx=\"2\"/>';}}for(var i=0;i<=4;i++){var v=Math.round(max*i/4),y=pt+ch-ch*i/4;svg+='<text x=\"'+(pl-6)+'\" y=\"'+(y+4)+'\" text-anchor=\"end\" class=\"gf-eixo\">'+v+'</text>';svg+='<line x1=\"'+pl+'\" y1=\"'+y+'\" x2=\"'+(w-pr)+'\" y2=\"'+y+'\" class=\"gf-grade-linha\"/>';}for(var i=0;i<m;i++){var x=pl+i*(cw/m)+cw/m/2;svg+='<text x=\"'+x+'\" y=\"'+(pt+ch+16)+'\" text-anchor=\"middle\" class=\"gf-eixo\">'+rotulos[i]+'</text>';}this._finalizar(c,svg,w,altura,conteudo);},_linhas:function(c,itens,opcoes){var d=this._extrair(itens,opcoes),rotulos=d.rotulos,vpc=d.valoresPorCampo,altura=parseInt(opcoes.altura)||300,conteudo=opcoes.conteudo||'',cor=opcoes.cor||'',w=800,pl=50,pr=20,pt=20,pb=40,cw=w-pl-pr,ch=altura-pt-pb,max=this._maximo(vpc),m=rotulos.length||1,svg='';for(var i=0;i<=4;i++){var v=Math.round(max*i/4),y=pt+ch-ch*i/4;svg+='<text x=\"'+(pl-6)+'\" y=\"'+(y+4)+'\" text-anchor=\"end\" class=\"gf-eixo\">'+v+'</text>';svg+='<line x1=\"'+pl+'\" y1=\"'+y+'\" x2=\"'+(w-pr)+'\" y2=\"'+y+'\" class=\"gf-grade-linha\"/>';}for(var si=0;si<d.camposValor.length;si++){var path='',corSerie=cor?this._resolverCor(cor):this._cores[si%10];for(var i=0;i<m;i++){var x=pl+i*(cw/(m-1||1)),y=pt+ch-(vpc[si][i]/max)*ch;path+=(i===0?'M':'L')+x+' '+y+' ';}svg+='<path d=\"'+path+'\" fill=\"none\" stroke=\"'+corSerie+'\" stroke-width=\"2\" class=\"gf-linha\"/>';for(var i=0;i<m;i++){var x=pl+i*(cw/(m-1||1)),y=pt+ch-(vpc[si][i]/max)*ch;svg+='<circle cx=\"'+x+'\" cy=\"'+y+'\" r=\"3\" fill=\"'+corSerie+'\" class=\"gf-ponto\"/>';}}for(var i=0;i<m;i++){var x=pl+i*(cw/(m-1||1));svg+='<text x=\"'+x+'\" y=\"'+(pt+ch+16)+'\" text-anchor=\"middle\" class=\"gf-eixo\">'+rotulos[i]+'</text>';}this._finalizar(c,svg,w,altura,conteudo,d.camposValor.length>1?d.camposValor:null);},_pizza:function(c,itens,opcoes){var campoRotulo=opcoes.rotulo,campoValor=opcoes.valor,altura=parseInt(opcoes.altura)||300,conteudo=opcoes.conteudo||'',rotulos=itens.map(function(d){return d[campoRotulo];}),valores=itens.map(function(d){return Number(d[campoValor])||0;}),cx=400,cy=altura/2,r=Math.min(cx,cy)-20,total=valores.reduce(function(a,b){return a+b;},0)||1,angulo=0,svg='';for(var i=0;i<valores.length;i++){var fatia=valores[i]/total*Math.PI*2,x1=cx+r*Math.cos(angulo),y1=cy+r*Math.sin(angulo),x2=cx+r*Math.cos(angulo+fatia),y2=cy+r*Math.sin(angulo+fatia),grande=fatia>Math.PI?1:0;svg+='<path d=\"M'+cx+' '+cy+' L'+x1+' '+y1+' A'+r+' '+r+' 0 '+grande+' 1 '+x2+' '+y2+' Z\" fill=\"'+this._cores[i%10]+'\" class=\"gf-fatia\"/>';var mx=cx+r*0.65*Math.cos(angulo+fatia/2),my=cy+r*0.65*Math.sin(angulo+fatia/2),perc=Math.round(valores[i]/total*100);svg+='<text x=\"'+mx+'\" y=\"'+my+'\" text-anchor=\"middle\" fill=\"#fff\" font-size=\"11\" font-weight=\"600\">'+perc+'%</text>';angulo+=fatia;}this._finalizar(c,svg,800,altura,conteudo,rotulos);},_area:function(c,itens,opcoes){var campoRotulo=opcoes.rotulo,campoValor=opcoes.valor,altura=parseInt(opcoes.altura)||300,conteudo=opcoes.conteudo||'',cor=opcoes.cor||'',w=800,pl=50,pr=20,pt=20,pb=40,cw=w-pl-pr,ch=altura-pt-pb,rotulos=itens.map(function(d){return d[campoRotulo];}),valores=itens.map(function(d){return Number(d[campoValor])||0;}),max=Math.max(Math.max.apply(null,valores)*1.1,1),m=rotulos.length||1,corLinha=cor?this._resolverCor(cor):this._cores[0],svg='';for(var i=0;i<=4;i++){var v=Math.round(max*i/4),y=pt+ch-ch*i/4;svg+='<text x=\"'+(pl-6)+'\" y=\"'+(y+4)+'\" text-anchor=\"end\" class=\"gf-eixo\">'+v+'</text>';svg+='<line x1=\"'+pl+'\" y1=\"'+y+'\" x2=\"'+(w-pr)+'\" y2=\"'+y+'\" class=\"gf-grade-linha\"/>';}var path='',area='M'+pl+' '+(pt+ch)+' ';for(var i=0;i<m;i++){var x=pl+i*(cw/(m-1||1)),y=pt+ch-(valores[i]/max)*ch;path+=(i===0?'M':'L')+x+' '+y+' ';area+='L'+x+' '+y+' ';}area+='L'+(pl+cw)+' '+(pt+ch)+' Z';svg+='<path d=\"'+area+'\" fill=\"'+corLinha+'\" opacity=\"0.15\" class=\"gf-area\"/>';svg+='<path d=\"'+path+'\" fill=\"none\" stroke=\"'+corLinha+'\" stroke-width=\"2\"/>';for(var i=0;i<m;i++){var x=pl+i*(cw/(m-1||1)),y=pt+ch-(valores[i]/max)*ch;svg+='<circle cx=\"'+x+'\" cy=\"'+y+'\" r=\"3\" fill=\"'+corLinha+'\" class=\"gf-ponto\"/>';}for(var i=0;i<m;i++){var x=pl+i*(cw/(m-1||1));svg+='<text x=\"'+x+'\" y=\"'+(pt+ch+16)+'\" text-anchor=\"middle\" class=\"gf-eixo\">'+rotulos[i]+'</text>';}this._finalizar(c,svg,w,altura,conteudo);},_radar:function(c,itens,opcoes){var camposValor=opcoes.valor.split(',').map(function(s){return s.trim();}),altura=parseInt(opcoes.altura)||360,conteudo=opcoes.conteudo||'',cor=opcoes.cor||'',w=800,cx=w/2,cy=altura/2,raio=Math.min(cx,cy)-50,n=camposValor.length,aneis=4,svg='';for(var a=1;a<=aneis;a++){var pontos='',rAtual=raio*a/aneis;for(var i=0;i<n;i++){var ang=(Math.PI*2*i/n)-Math.PI/2,x=cx+rAtual*Math.cos(ang),y=cy+rAtual*Math.sin(ang);pontos+=x+','+y+' ';}svg+='<polygon points=\"'+pontos+'\" class=\"gf-radar-anel\"/>';}for(var i=0;i<n;i++){var ang=(Math.PI*2*i/n)-Math.PI/2,x=cx+raio*Math.cos(ang),y=cy+raio*Math.sin(ang);svg+='<line x1=\"'+cx+'\" y1=\"'+cy+'\" x2=\"'+x+'\" y2=\"'+y+'\" class=\"gf-radar-eixo\"/>';var lx=cx+(raio+22)*Math.cos(ang),ly=cy+(raio+22)*Math.sin(ang);svg+='<text x=\"'+lx+'\" y=\"'+ly+'\" text-anchor=\"middle\" class=\"gf-radar-rotulo\">'+camposValor[i]+'</text>';}itens.forEach(function(item,idx){var maxGlobal=1;camposValor.forEach(function(cv){itens.forEach(function(it2){var v=Number(it2[cv])||0;if(v>maxGlobal)maxGlobal=v;});});var pontos='';for(var i=0;i<n;i++){var val=Number(item[camposValor[i]])||0,ang=(Math.PI*2*i/n)-Math.PI/2,r=(val/maxGlobal)*raio,x=cx+r*Math.cos(ang),y=cy+r*Math.sin(ang);pontos+=x+','+y+' ';}var corItem=cor?this._resolverCor(cor):this._cores[idx%5];svg+='<polygon points=\"'+pontos+'\" fill=\"'+corItem+'\" fill-opacity=\"0.18\" stroke=\"'+corItem+'\" stroke-width=\"2\" class=\"gf-radar-area\"/>';},this);this._finalizar(c,svg,w,altura,conteudo);},_finalizar:function(c,svg,w,altura,conteudo,legendaItens){var html='';if(conteudo)html+='<div class=\"gf-titulo\">'+conteudo+'</div>';html+='<svg viewBox=\"0 0 '+w+' '+altura+'\" style=\"width:100%;height:'+altura+'px;\">'+svg+'</svg>';if(legendaItens&&legendaItens.length>0){html+='<div class=\"gf-legenda\">';legendaItens.forEach(function(label,idx){html+='<div class=\"gf-legenda-item\"><div class=\"gf-legenda-cor\" style=\"background:'+this._cores[idx%10]+'\"></div>'+label+'</div>';},this);html+='</div>';}c.innerHTML=html;}};",

  "componentes": {
    "grafico": {
      "template": "<div id=\"gf_{{ref}}\" class=\"gf-grafico\"></div><script>if(typeof gt!=='undefined'&&gt._render){try{gt._render('gf_{{ref}}',{{itens}},{tipo:'{{tipo}}',rotulo:'{{rotulo}}',valor:'{{valor}}',altura:{{altura}},conteudo:'{{conteudo}}',cor:'{{cor}}'});}catch(e){console.error('gt:grafico error',e);}}</script>",
      "atributos": ["ref", "itens", "tipo", "rotulo", "valor", "altura", "conteudo", "cor"]
    }
  },

  "funcoes": {}
}
