{
  "id": "interface.modal",
  "alias": "md",
  "versao": "1.0",
  "autor": "comunidade-chorty",
  "descricao": "Sistema de modais elegantes — janelas flutuantes para confirmações, avisos e menus de opções. Suporte a transições, cores customizáveis e dois tipos de exibição.",
  "namespace": "window._chortyMd",
  "estilos": ".chorty-modal-overlay{display:none;position:fixed;inset:0;z-index:99990;align-items:center;justify-content:center;padding:16px;}.chorty-modal-overlay.aberto{display:flex;}.chorty-modal-overlay.surgir.aberto{animation:_chortyMdFadeIn .25s ease;}.chorty-modal-overlay.salto .chorty-modal-caixa{animation:_chortyMdSalto .4s ease;}.chorty-modal-overlay.deslizar .chorty-modal-caixa{animation:_chortyMdDeslizar .3s ease;}.chorty-modal-overlay.instantaneo.aberto{animation:none;}.chorty-modal-caixa{border-radius:16px;padding:28px 24px 20px;max-width:360px;width:100%;box-shadow:0 20px 60px rgba(0,0,0,.25);font-family:system-ui,sans-serif;}.chorty-modal-destaque{font-size:1.1rem;font-weight:700;margin-bottom:8px;}.chorty-modal-conteudo{font-size:.9rem;line-height:1.5;margin-bottom:20px;}.chorty-modal-botoes{display:flex;gap:8px;justify-content:flex-end;}.chorty-modal-btn{border:none;border-radius:10px;padding:10px 20px;font-size:.9rem;font-weight:600;cursor:pointer;}.chorty-modal-sheet{position:fixed;bottom:0;left:0;right:0;z-index:99991;display:none;border-radius:20px 20px 0 0;padding:20px 0 30px;box-shadow:0 -4px 24px rgba(0,0,0,.15);font-family:system-ui,sans-serif;}.chorty-modal-sheet.aberto{display:block;}.chorty-modal-sheet-destaque{font-size:1rem;font-weight:700;padding:0 24px 14px;border-bottom:1px solid #e2e8f0;margin-bottom:6px;}.chorty-modal-sheet-opcao{display:block;width:100%;padding:14px 24px;font-size:.95rem;background:none;border:none;text-align:left;cursor:pointer;}.chorty-modal-sheet-opcao:hover{opacity:0.8;}@keyframes _chortyMdFadeIn{from{opacity:0}to{opacity:1}}@keyframes _chortyMdSalto{0%{transform:scale(.85)}60%{transform:scale(1.04)}100%{transform:scale(1)}}@keyframes _chortyMdDeslizar{from{transform:translateY(-30px);opacity:0}to{transform:translateY(0);opacity:1}}",
  "scripts": "window._chortyMd = window._chortyMd || {_cores:{branco:'#ffffff',azul:'#2563eb',azul_claro:'#dbeafe',preto:'#0f172a',vermelho:'#dc2626',verde:'#16a34a',amarelo:'#ca8a04',roxo:'#7c3aed',cinza:'#64748b',laranja:'#ea580c',rosa:'#db2777',ciano:'#0891b2',turquesa:'#0d9488',indigo:'#4338ca',cinza_claro:'#f1f5f9',cinza_escuro:'#334155'},_criar:function(el){var s=this;var ref=el.getAttribute('data-modal-ref');var tipo=el.getAttribute('data-modal-tipo')||'normal';var destaque=el.getAttribute('data-modal-destaque')||'';var conteudo=el.getAttribute('data-modal-conteudo')||'';var positivo=el.getAttribute('data-modal-positivo')||'Sim';var negativo=el.getAttribute('data-modal-negativo')||'Nao';var transicao=el.getAttribute('data-modal-transicao')||'surgir';var opcoes=(el.getAttribute('data-modal-opcoes')||'').split(',').filter(Boolean);var corFundo=s._cores[el.getAttribute('data-modal-cor-fundo')]||el.getAttribute('data-modal-cor-fundo')||'#ffffff';var corTexto=s._cores[el.getAttribute('data-modal-cor-texto')]||el.getAttribute('data-modal-cor-texto')||'#1e293b';var corDestaque=s._cores[el.getAttribute('data-modal-cor-destaque')]||el.getAttribute('data-modal-cor-destaque')||'#1e293b';var corBotaoSim=s._cores[el.getAttribute('data-modal-cor-botao-sim')]||el.getAttribute('data-modal-cor-botao-sim')||'#2563eb';var corBotaoNao=s._cores[el.getAttribute('data-modal-cor-botao-nao')]||el.getAttribute('data-modal-cor-botao-nao')||'#e2e8f0';var corTextoBotaoSim=s._cores[el.getAttribute('data-modal-cor-texto-sim')]||el.getAttribute('data-modal-cor-texto-sim')||'#ffffff';var corTextoBotaoNao=s._cores[el.getAttribute('data-modal-cor-texto-nao')]||el.getAttribute('data-modal-cor-texto-nao')||'#475569';var corOverlay=el.getAttribute('data-modal-cor-overlay')||'rgba(15,23,42,.55)';var html='';if(tipo==='opcoes'){html+='<div class=\"chorty-modal-sheet\" id=\"modal-'+ref+'\" data-transicao=\"'+transicao+'\" style=\"background:'+corFundo+';color:'+corTexto+';\">';if(destaque){html+='<div class=\"chorty-modal-sheet-destaque\" style=\"color:'+corDestaque+';\">'+destaque+'</div>';}opcoes.forEach(function(op){html+='<button class=\"chorty-modal-sheet-opcao\" style=\"color:'+corTexto+';\" onclick=\"window._chortyMd.fechar(\\''+ref+'\\')\">'+op.trim()+'</button>';});html+='<button class=\"chorty-modal-sheet-opcao\" style=\"color:#64748b;\" onclick=\"window._chortyMd.fechar(\\''+ref+'\\')\">Cancelar</button>';html+='</div>';}else{html+='<div class=\"chorty-modal-overlay\" id=\"modal-'+ref+'\" data-transicao=\"'+transicao+'\" style=\"background:'+corOverlay+';\">';html+='<div class=\"chorty-modal-caixa\" style=\"background:'+corFundo+';color:'+corTexto+';\">';if(destaque){html+='<div class=\"chorty-modal-destaque\" style=\"color:'+corDestaque+';\">'+destaque+'</div>';}html+='<div class=\"chorty-modal-conteudo\" style=\"color:'+corTexto+';\">'+conteudo+'</div>';html+='<div class=\"chorty-modal-botoes\">';html+='<button class=\"chorty-modal-btn\" style=\"background:'+corBotaoNao+';color:'+corTextoBotaoNao+';\" onclick=\"window._chortyMd.fechar(\\''+ref+'\\')\">'+negativo+'</button>';html+='<button class=\"chorty-modal-btn\" style=\"background:'+corBotaoSim+';color:'+corTextoBotaoSim+';\" onclick=\"window._chortyMd.fechar(\\''+ref+'\\')\">'+positivo+'</button>';html+='</div></div></div>';}el.outerHTML=html;},abrir:function(ref){var el=document.getElementById('modal-'+ref);if(!el)return;var t=el.getAttribute('data-transicao')||'surgir';el.classList.add(t);el.classList.add('aberto');},fechar:function(ref){var el=document.getElementById('modal-'+ref);if(!el)return;var t=el.getAttribute('data-transicao')||'surgir';el.classList.remove('aberto');setTimeout(function(){el.classList.remove(t);},300);},estaAberto:function(ref){var el=document.getElementById('modal-'+ref);return!!(el&&el.classList.contains('aberto'));}};document.addEventListener('DOMContentLoaded',function(){document.querySelectorAll('[data-modal-ref]').forEach(function(el){window._chortyMd._criar(el);});});",
  "componentes": {
    "modal": {
      "template": "<div data-modal-ref=\"{{ref}}\" data-modal-tipo=\"{{tipo}}\" data-modal-destaque=\"{{destaque}}\" data-modal-conteudo=\"{{conteudo}}\" data-modal-positivo=\"{{positivo}}\" data-modal-negativo=\"{{negativo}}\" data-modal-transicao=\"{{transicao}}\" data-modal-opcoes=\"{{opcoes}}\" data-modal-cor-fundo=\"{{cor_fundo}}\" data-modal-cor-texto=\"{{cor_texto}}\" data-modal-cor-destaque=\"{{cor_destaque}}\" data-modal-cor-botao-sim=\"{{cor_botao_sim}}\" data-modal-cor-botao-nao=\"{{cor_botao_nao}}\" data-modal-cor-texto-sim=\"{{cor_texto_sim}}\" data-modal-cor-texto-nao=\"{{cor_texto_nao}}\" data-modal-cor-overlay=\"{{cor_overlay}}\"></div>",
      "atributos": ["ref", "tipo", "destaque", "conteudo", "positivo", "negativo", "transicao", "opcoes", "cor_fundo", "cor_texto", "cor_destaque", "cor_botao_sim", "cor_botao_nao", "cor_texto_sim", "cor_texto_nao", "cor_overlay"]
    }
  },
  "funcoes": {
    "abrir": { "params": ["ref"], "js": "" },
    "fechar": { "params": ["ref"], "js": "" },
    "estaAberto": { "params": ["ref"], "js": "" }
  }
}